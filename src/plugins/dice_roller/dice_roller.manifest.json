    "publish_events": true,
    "subscribe_events": false
  },

  "events": {
    "publishes": [
      "dice.rolled"
    ],
    "subscribes": []
  },

  "ui": {
    "window_title": "Dice Roller",
    "default_width": 400,
    "default_height": 500,
    "resizable": true,
    "can_dock": true
  }
}
