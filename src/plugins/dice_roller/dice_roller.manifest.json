{
  "id": "dice_roller",
  "name": "Dice Roller",
  "description": "Lanceur de dés pour D&D 5e avec historique",
  "version": "1.0.0",
  "author": "D&D DM Toolbox Team",

  "menu": {
    "category": "Jeu",
    "order": 1,
    "icon": "🎲",
    "shortcuts": ["Ctrl+D"]
  },

  "requires": {
